package personagem;

public class Heroi extends Personagem {
    private String nome;
    private int ataque;

    public Heroi(String nome, int vida, int defesa, int defesaMagica, int ataque){
        super(vida, defesa, defesaMagica);
        this.nome = nome;
        this.ataque = ataque;
    }

    public String getNome() {
        return nome;
    }

    public int getAtaque() {
        return ataque;
    }

    @Override
    public void mostraDados(){
        System.out.println("Herói: " + nome);
        super.mostraDados();
        System.out.println("Ataque: " + ataque);
    }
}
